@page
@model FixClient.Web.Pages.SessionsIndexModel
@{
    ViewData["Title"] = "Sessions";
}

<div class="grid grid-2">
    <div class="card">
        <div class="card-header"><h2>Create Session</h2></div>
        <div class="card-body">
            <form method="post">
                <h3 style="margin:0 0 0.75rem;font-size:0.95rem;color:#e2e8f0;border-bottom:1px solid #334155;padding-bottom:0.5rem;">Required</h3>
                <div class="form-group">
                    <label>Behaviour</label>
                    <select name="Behaviour" class="form-control">
                        <option>Initiator</option>
                        <option>Acceptor</option>
                    </select>
                </div>
                <div class="grid grid-2">
                    <div class="form-group">
                        <label>SenderCompID</label>
                        <input type="text" name="SenderCompId" class="form-control" value="" placeholder="SENDER" />
                    </div>
                    <div class="form-group">
                        <label>TargetCompID</label>
                        <input type="text" name="TargetCompId" class="form-control" value="" placeholder="TARGET" />
                    </div>
                </div>
                <div class="grid grid-2">
                    <div class="form-group">
                        <label>Host</label>
                        <input type="text" name="Host" class="form-control" value="127.0.0.1" />
                    </div>
                    <div class="form-group">
                        <label>Port</label>
                        <input type="number" name="Port" class="form-control" value="9810" />
                    </div>
                </div>
                <div class="grid grid-2">
                    <div class="form-group">
                        <label>FIX Version</label>
                        <select name="BeginString" class="form-control">
                            @foreach (var v in Model.Versions)
                            {
                                <option value="@v" selected="@(v == "FIX.5.0SP2")">@v</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>HeartBtInt</label>
                        <input type="number" name="HeartBtInt" class="form-control" value="30" />
                    </div>
                </div>

                <details style="margin-top:1rem;">
                    <summary style="cursor:pointer;font-size:0.95rem;color:#e2e8f0;border-bottom:1px solid #334155;padding-bottom:0.5rem;margin-bottom:0.75rem;">Optional</summary>

                    <h4 style="margin:0.75rem 0 0.5rem;font-size:0.85rem;color:#94a3b8;">Session</h4>
                    <div class="grid grid-2">
                        <div class="form-group">
                            <label>Order Flow</label>
                            <select name="OrderBehaviour" class="form-control">
                                <option>Initiator</option>
                                <option>Acceptor</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Logon Behaviour</label>
                            <select name="LogonBehaviour" class="form-control">
                                <option value="">(same as Behaviour)</option>
                                <option>Initiator</option>
                                <option>Acceptor</option>
                            </select>
                        </div>
                    </div>
                    <div class="grid grid-2">
                        <div class="form-group">
                            <label>Default Application Version</label>
                            <select name="DefaultApplVerId" class="form-control">
                                <option value="">(same as FIX Version)</option>
                                @foreach (var v in Model.Versions)
                                {
                                    <option value="@v">@v</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label>TestRequest Delay</label>
                            <input type="number" name="TestRequestDelay" class="form-control" value="2" />
                        </div>
                    </div>
                    <div class="grid grid-3">
                        <div class="form-group">
                            <label style="display:flex;align-items:center;gap:0.5rem;">
                                <input type="checkbox" name="BrokenNewSeqNo" value="true" />
                                Broken NewSeqNo
                            </label>
                        </div>
                        <div class="form-group">
                            <label style="display:flex;align-items:center;gap:0.5rem;">
                                <input type="checkbox" name="NextExpectedMsgSeqNum" value="true" />
                                NextExpectedMsgSeqNum
                            </label>
                        </div>
                        <div class="form-group">
                            <label style="display:flex;align-items:center;gap:0.5rem;">
                                <input type="checkbox" name="ValidateDataFields" value="true" checked />
                                Validate Data Fields
                            </label>
                        </div>
                    </div>

                    <h4 style="margin:0.75rem 0 0.5rem;font-size:0.85rem;color:#94a3b8;">Message Generation</h4>
                    <div class="grid grid-3">
                        <div class="form-group">
                            <label>Incoming MsgSeqNum</label>
                            <input type="number" name="IncomingSeqNum" class="form-control" value="1" min="1" />
                        </div>
                        <div class="form-group">
                            <label>Outgoing MsgSeqNum</label>
                            <input type="number" name="OutgoingSeqNum" class="form-control" value="1" min="1" />
                        </div>
                        <div class="form-group">
                            <label>Test Request ID</label>
                            <input type="number" name="TestRequestId" class="form-control" value="0" min="0" />
                        </div>
                    </div>

                    <h4 style="margin:0.75rem 0 0.5rem;font-size:0.85rem;color:#94a3b8;">Network</h4>
                    <div class="form-group">
                        <label style="display:flex;align-items:center;gap:0.5rem;">
                            <input type="checkbox" name="FragmentMessages" value="true" checked />
                            Fragment Messages
                        </label>
                    </div>
                </details>

                <div class="toolbar" style="margin-top:1rem;">
                    <button type="submit" class="btn btn-primary">Create Session</button>
                </div>
            </form>
        </div>
    </div>
    <div class="card">
        <div class="card-header"><h2>Active Sessions (@Model.SessionList.Count)</h2></div>
        <div class="card-body" style="max-height:50vh;overflow-y:auto;">
            @if (Model.SessionList.Count == 0)
            {
                <div class="empty-state">
                    <p>No sessions. Create one using the form.</p>
                </div>
            }
            else
            {
                @foreach (var s in Model.SessionList)
                {
                    var displayState = s.Behaviour == "Acceptor" && s.State == "Connected" ? "Listening" : s.State;
                    <div class="card" data-session-id="@s.Id" data-behaviour="@s.Behaviour" style="margin-bottom:0.75rem;border-color:@(s.State == "Disconnected" ? "#334155" : s.State == "LoggedOn" ? "#166534" : "#854d0e");">
                        <div class="card-body" style="padding:0.75rem;">
                            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem;">
                                <div>
                                    <span class="badge badge-blue">@s.Id</span>
                                    <strong style="margin-left:0.5rem;">@s.SenderCompId ? @s.TargetCompId</strong>
                                </div>
                                <span class="badge session-state @(s.State == "Disconnected" ? "badge-gray" : s.State == "LoggedOn" ? "badge-green" : "badge-amber")">@displayState</span>
                            </div>
                            <div style="font-size:0.8rem;color:#64748b;margin-bottom:0.5rem;">
                                @s.BeginString &middot; @s.Behaviour &middot; @s.Host:@s.Port &middot; HB=@s.HeartBtInt
                            </div>
                            <div class="toolbar">
                                <a href="/Sessions/Detail?sessionId=@s.Id" class="btn btn-primary btn-sm">Open</a>
                                <form method="post" asp-page-handler="Enable" style="display:inline;">
                                    <input type="hidden" name="SessionId" value="@s.Id" />
                                    <button type="submit" class="btn btn-secondary btn-sm session-enable" @(s.State != "Disconnected" ? "disabled" : "")>Enable</button>
                                </form>
                                <form method="post" asp-page-handler="Disable" style="display:inline;">
                                    <input type="hidden" name="SessionId" value="@s.Id" />
                                    <button type="submit" class="btn btn-secondary btn-sm session-disable" @(s.State == "Disconnected" ? "disabled" : "")>Disable</button>
                                </form>
                                <a href="/History?sessionId=@s.Id" class="btn btn-secondary btn-sm">History (<span class="session-history-count">@s.HistoryCount</span>)</a>
                                <a href="/Log?sessionId=@s.Id" class="btn btn-secondary btn-sm">Log (<span class="session-log-count">@s.LogCount</span>)</a>
                                <form method="post" asp-page-handler="Remove" style="display:inline;">
                                    <input type="hidden" name="SessionId" value="@s.Id" />
                                    <button type="submit" class="btn btn-secondary btn-sm" style="color:#f87171;">Remove</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        (function () {
            var cards = Array.from(document.querySelectorAll('[data-session-id]'));
            if (cards.length === 0) return;

            var connection = new signalR.HubConnectionBuilder()
                .withUrl('/hubs/session')
                .withAutomaticReconnect()
                .build();

            function updateState(sessionId, state) {
                var card = document.querySelector('[data-session-id="' + sessionId + '"]');
                if (!card) return;

                var stateBadge = card.querySelector('.session-state');
                var enableButton = card.querySelector('.session-enable');
                var disableButton = card.querySelector('.session-disable');

                var behaviour = card.dataset.behaviour;
                var displayState = (behaviour === 'Acceptor' && state === 'Connected') ? 'Listening' : state;

                if (stateBadge) {
                    stateBadge.textContent = displayState;
                    stateBadge.classList.remove('badge-gray', 'badge-green', 'badge-amber');
                    if (state === 'Disconnected') {
                        stateBadge.classList.add('badge-gray');
                    } else if (state === 'LoggedOn') {
                        stateBadge.classList.add('badge-green');
                    } else {
                        stateBadge.classList.add('badge-amber');
                    }
                }

                if (enableButton) enableButton.disabled = state !== 'Disconnected';
                if (disableButton) disableButton.disabled = state === 'Disconnected';

                if (state === 'Disconnected') {
                    card.style.borderColor = '#334155';
                } else if (state === 'LoggedOn') {
                    card.style.borderColor = '#166534';
                } else {
                    card.style.borderColor = '#854d0e';
                }
            }

            function incrementCount(sessionId, selector) {
                var card = document.querySelector('[data-session-id="' + sessionId + '"]');
                if (!card) return;
                var el = card.querySelector(selector);
                if (!el) return;
                var current = parseInt(el.textContent || '0', 10);
                el.textContent = String((isNaN(current) ? 0 : current) + 1);
            }

            connection.on('StateChanged', function (sessionId, state) {
                updateState(sessionId, state);
            });

            connection.on('MessageReceived', function (sessionId) {
                incrementCount(sessionId, '.session-history-count');
            });

            connection.on('MessageSent', function (sessionId) {
                incrementCount(sessionId, '.session-history-count');
            });

            connection.on('LogAdded', function (sessionId) {
                incrementCount(sessionId, '.session-log-count');
            });

            function joinAllSessions() {
                cards.forEach(function (card) {
                    if (card.dataset.sessionId) {
                        connection.invoke('JoinSession', card.dataset.sessionId);
                    }
                });
            }

            connection.start().then(joinAllSessions);
            connection.onreconnected(joinAllSessions);
        })();
    </script>
}
