@page
@model FixClient.Web.Pages.HistoryIndexModel
@{
    ViewData["Title"] = "Message History";
}

@if (!Model.Found)
{
    <div class="card">
        <div class="card-header"><h2>Select a Session</h2></div>
        <div class="card-body">
            @if (Model.AllSessions.Count == 0)
            {
                <div class="empty-state">
                    <p>No sessions available. <a href="/Sessions">Create a session</a> first.</p>
                </div>
            }
            else
            {
                <div style="display:flex;flex-wrap:wrap;gap:0.75rem;">
                    @foreach (var s in Model.AllSessions)
                    {
                        <a href="/History?sessionId=@s.Id" class="card" style="flex:0 0 auto;text-decoration:none;border-color:#334155;min-width:200px;">
                            <div class="card-body" style="padding:0.75rem;">
                                <div style="font-weight:600;">@s.SenderCompId ? @s.TargetCompId</div>
                                <div style="font-size:0.8rem;color:#64748b;">
                                    <span class="badge @(s.State == "LoggedOn" ? "badge-green" : "badge-gray")">@s.State</span>
                                    &middot; @s.HistoryCount messages
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;">
            <h2>@Model.SessionLabel</h2>
            <div>
                <span class="badge @(Model.SessionState == "LoggedOn" ? "badge-green" : Model.SessionState == "Disconnected" ? "badge-gray" : "badge-amber")">@Model.SessionState</span>
                <a href="/Sessions/Detail?sessionId=@Model.SessionId" class="btn btn-primary btn-sm" style="margin-left:0.5rem;">Session Workspace</a>
                <a href="/Sessions" class="btn btn-secondary btn-sm" style="margin-left:0.25rem;">Back</a>
            </div>
        </div>
    </div>

    <div class="card" style="margin-top:1rem;">
        <div class="card-header">
            <h2>Messages (@Model.HistoryEntries.Count)</h2>
        </div>
        <div class="card-body" id="historyContainer" style="max-height:70vh;overflow-y:auto;">
            @if (Model.HistoryEntries.Count == 0)
            {
                <div class="empty-state" id="emptyState">
                    <p>No messages yet. Connect the session and messages will appear here in real-time.</p>
                </div>
            }

            <table class="data-table" id="historyTable" style="@(Model.HistoryEntries.Count == 0 ? "display:none;" : "")">
                <thead>
                    <tr>
                        <th>Time</th>
                        <th>Direction</th>
                        <th>MsgType</th>
                        <th>Type</th>
                        <th>SeqNum</th>
                        <th>Summary</th>
                    </tr>
                </thead>
                <tbody id="historyBody">
                    @foreach (var entry in Model.HistoryEntries)
                    {
                        <tr class="@(entry.Direction == "Incoming" ? "row-incoming" : "row-outgoing")" title="@entry.Raw">
                            <td style="white-space:nowrap;">@entry.Timestamp.ToString("HH:mm:ss.fff")</td>
                            <td><span class="badge @(entry.Direction == "Incoming" ? "badge-blue" : "badge-green")">@entry.Direction</span></td>
                            <td><code>@entry.MsgType</code></td>
                            <td>@entry.MsgTypeName</td>
                            <td>@entry.SeqNum</td>
                            <td style="font-size:0.8rem;color:#94a3b8;">@entry.Summary</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        (function () {
            var sessionId = '@Model.SessionId';
            if (!sessionId) return;

            var connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/session")
                .withAutomaticReconnect()
                .build();

            function addRow(entry) {
                var emptyState = document.getElementById('emptyState');
                if (emptyState) emptyState.style.display = 'none';
                var table = document.getElementById('historyTable');
                if (table) table.style.display = '';

                var tbody = document.getElementById('historyBody');
                var row = document.createElement('tr');
                row.className = entry.direction === 'Incoming' ? 'row-incoming' : 'row-outgoing';
                row.title = entry.raw || '';
                var time = new Date(entry.timestamp);
                var ts = time.toTimeString().split(' ')[0] + '.' + String(time.getMilliseconds()).padStart(3, '0');
                row.innerHTML =
                    '<td style="white-space:nowrap;">' + ts + '</td>' +
                    '<td><span class="badge ' + (entry.direction === 'Incoming' ? 'badge-blue' : 'badge-green') + '">' + entry.direction + '</span></td>' +
                    '<td><code>' + (entry.msgType || '') + '</code></td>' +
                    '<td>' + (entry.msgTypeName || '') + '</td>' +
                    '<td>' + (entry.seqNum || 0) + '</td>' +
                    '<td style="font-size:0.8rem;color:#94a3b8;">' + (entry.summary || '') + '</td>';
                tbody.insertBefore(row, tbody.firstChild);
            }

            connection.on("MessageReceived", function (id, entry) {
                addRow(entry || id);
            });
            connection.on("MessageSent", function (id, entry) {
                addRow(entry || id);
            });
            connection.on("StateChanged", function (id, state) {
                var sessionState = state || id;
                var header = document.querySelector('.card .card-header');
                if (!header) return;

                var badge = header.querySelector('.badge');
                if (!badge) return;

                badge.textContent = sessionState;
                badge.classList.remove('badge-green', 'badge-gray', 'badge-amber');

                if (sessionState === 'LoggedOn') {
                    badge.classList.add('badge-green');
                } else if (sessionState === 'Disconnected') {
                    badge.classList.add('badge-gray');
                } else {
                    badge.classList.add('badge-amber');
                }
            });

            connection.start().then(function () {
                connection.invoke("JoinSession", sessionId);
            });

            connection.onreconnected(function () {
                connection.invoke("JoinSession", sessionId);
            });
        })();
    </script>
}
